# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google OAuth2 + Gmail API
# Crée un projet sur https://console.cloud.google.com
# Active l'API Gmail + Cloud Pub/Sub
# Crée des identifiants OAuth 2.0 (Application web)
# Redirect URI: http://127.0.0.1:54321/functions/v1/oauth-callback (dev)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Cloud Pub/Sub
# Format: projects/{project_id}/topics/{topic_name}
# Le topic doit accorder les droits publish à gmail-api-push@system.gserviceaccount.com
GOOGLE_PUBSUB_TOPIC=projects/YOUR_PROJECT_ID/topics/gmail-push

# Token pour valider les webhooks Pub/Sub (ajoute ?token=SECRET à l'URL push)
PUBSUB_SECRET=generate_a_random_secret_here

# Gemini Flash (gratuit via AI Studio: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Chiffrement AES-256 pour les tokens OAuth stockés en DB
# Génère avec: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# URL du frontend (pour les redirections OAuth)
APP_URL=http://localhost:5173

# URI de redirection OAuth (doit correspondre exactement à ce qui est enregistré dans Google Cloud Console)
# Dev local : http://localhost:54321/functions/v1/oauth-callback
# Production : https://<ref>.supabase.co/functions/v1/oauth-callback
OAUTH_REDIRECT_URI=http://localhost:54321/functions/v1/oauth-callback

# Telegram Bot
# Crée un bot via @BotFather sur Telegram → copie le token
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Secret webhook (random) — doit correspondre au secret_token passé à setWebhook
# Génère avec: openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=generate_a_random_secret_here
