VITE_SUPABASE_URL=http://localhost:54321
# Clé "Publishable" affichée par `supabase start` (pas la Secret/service_role)
VITE_SUPABASE_ANON_KEY=your_publishable_key_here
# Google Client ID (pas secret — exposé côté client pour le OAuth redirect)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
# Nom du bot Telegram (sans @) — pour le deep link "Ouvrir dans Telegram"
VITE_TELEGRAM_BOT_NAME=your_sesame_bot
